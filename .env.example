# Nanobot Management Center Configuration
# Copy this file to .env.local and modify as needed

# Profiles directory (where nanobot instance data is stored)
# Auto-detected: checks parent directory for 'profiles/' folder
# Uncomment and set manually if needed:
# PROFILES_DIR=/opt/1panel/docker/compose/nanobot/profiles

# Docker socket path
# Default: /var/run/docker.sock (Linux/macOS)
# Windows: //./pipe/docker_engine
# DOCKER_SOCKET=/var/run/docker.sock

# Nanobot Docker image
# Default: nanobot:latest
# NANOBOT_IMAGE=nanobot:latest

# Database path (SQLite)
# Default: ./data/nanobot-admin.db
# DB_PATH=./data/nanobot-admin.db

# Server port
# Default: 3000
# PORT=3000
